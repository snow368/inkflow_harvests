rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: artists
    // Document ID: {artistId}
    // Fields:
    //   - id: string (required)
    //   - shopName: string
    //   - igLink: string
    //   - mapsRating: number
    //   - address: string
    //   - location: string
    //   - stage: string (required, enum: outreach, active, customers, dormant)
    //   - followers: number
    //   - activityLevel: string
    //   - style: string
    //   - dna_tags: list (strings)
    //   - lastScanned: string
    //   - isConverted: bool
    //   - account_tag: string
    //   - orderCount: number
    //   - totalSpent: number
    //   - lastOrderDate: string
    //   - profilePic: string
    //   - fullName: string
    //   - username: string
    //   - isHighIntent: bool
    //   - isRecommended: bool
    //   - heatScore: number
    //   - similarityScore: number
    //   - similarityWeight: number
    //   - baseScore: number
    //   - customerTier: string
    //   - lastInteractionDate: string
    //   - uid: string (required, owner)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "snow368@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidArtist(data) {
      return data.id is string &&
             data.stage in ['outreach', 'engaged', 'customers', 'dormant'] &&
             data.uid is string &&
             (!('followers' in data) || data.followers is number) &&
             (!('orderCount' in data) || data.orderCount is number) &&
             (!('totalSpent' in data) || data.totalSpent is number) &&
             (!('heatScore' in data) || data.heatScore is number);
    }

    function isValidInteraction(data) {
      return data.id is string &&
             data.artistId is string &&
             data.type in ['like', 'comment', 'follow', 'story_view', 'follow_back', 'reply', 'dm_reply'] &&
             data.weight is number &&
             data.uid is string;
    }

    function isValidOrder(data) {
      return data.id is string &&
             data.artistId is string &&
             data.amount is number &&
             data.uid is string;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    function isValidAccount(data) {
      return data.id is string &&
             data.username is string &&
             data.uid is string;
    }

    function isValidAssignment(data) {
      return data.id is string &&
             data.artistId is string &&
             data.accountId is string &&
             data.uid is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /artists/{artistId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidArtist(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidArtist(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /interactions/{id} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidInteraction(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidInteraction(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /orders/{id} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidOrder(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /accounts/{id} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidAccount(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidAccount(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /assignments/{id} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidAssignment(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidAssignment(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }
  }
}
